{
  "schemaVersion": 1,
  "id": "watchmenbot",
  "version": "${version}",
  "name": "WMBot",
  "description": "A Meteor Client addon for Minecraft 1.21.8.",
  "authors": [
    "sup3rd00b"
  ],
  "contact": {
    "sources": "https://github.com/sup3rd00b/omnibot"
  },
  "icon": "assets/watchmenbot/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.watchmenbot.WMBot"
    ]
  },
  "mixins": [
    "watchmenbot.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "77,180,255",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  },
  "suggests": {
    "baritone-meteor": "*",
    "baritone": "*"
  }
}
